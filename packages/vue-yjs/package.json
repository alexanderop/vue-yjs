{
  "name": "vue-yjs",
  "version": "0.1.0",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "lib0": "^0.2.94"
  },
  "peerDependencies": {
    "vue": "^3.3.0",
    "yjs": "^13.6.16",
    "y-protocols": "^1.0.6",
    "y-websocket": "^2.0.4",
    "y-indexeddb": "^9.0.12"
  },
  "peerDependenciesMeta": {
    "y-protocols": {
      "optional": true
    },
    "y-websocket": {
      "optional": true
    },
    "y-indexeddb": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^14.0.0",
    "vite": "^5.2.13",
    "vitest": "^1.6.0",
    "vue": "^3.4.0",
    "y-indexeddb": "^9.0.12",
    "y-protocols": "^1.0.6",
    "y-websocket": "^2.0.4",
    "yjs": "^13.6.16"
  }
}
